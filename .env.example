"""
Example environment configuration
Copy to .env and update values
"""

# Application
APP_NAME=Distributed Log Monitoring System
APP_VERSION=1.0.0
DEBUG=False
ENVIRONMENT=production

# API
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql://logadmin:logpass123@localhost:5432/logdb
DB_ECHO=False

# Elasticsearch
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_SCHEME=http
ELASTICSEARCH_INDEX_PREFIX=logs
ELASTICSEARCH_SHARDS=3
ELASTICSEARCH_REPLICAS=1

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_LOGS=logs
KAFKA_TOPIC_ALERTS=alerts
KAFKA_CONSUMER_GROUP=log_monitor
KAFKA_BATCH_SIZE=1000

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Alerting
ALERT_ENABLED=True
EMAIL_ENABLED=False
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SENDER=noreply@monitoring.local
SLACK_WEBHOOK_URL=

# Features
ANOMALY_DETECTION_ENABLED=True
REAL_TIME_STREAMING_ENABLED=True

# Performance
MAX_QUERY_RESULTS=10000
SEARCH_TIMEOUT_SECONDS=30
BATCH_PROCESSING_SIZE=5000
